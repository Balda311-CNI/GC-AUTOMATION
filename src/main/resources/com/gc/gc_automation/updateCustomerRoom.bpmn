    <bpmn2:scriptTask id="_ADD1A001-3333-4333-8333-ADD1A0010001" name="find serviceAccessCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find serviceAccessCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>flow_findservice_findsacc</bpmn2:incoming>
      <bpmn2:outgoing>flow_findsacc_gwsacc</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("updateCustomerRoom - find serviceAccessCrossId");
System.out.println("================================================");

boolean found = false;
if ( serviceComponents != null ) {
    for ( java.util.Map serviceComponent : (java.util.List<java.util.Map>) serviceComponents ) {
        if ( "SC_ACCESS".equals( serviceComponent.get("componentTypeName") ) ) {
            java.util.List resources = (java.util.List) serviceComponent.get("resources");
            if ( resources == null || resources.isEmpty() ) {
                kcontext.setVariable("errorMessage", "Service component SC_ACCESS has no resources");
                return;
            }
            java.util.Map resource = (java.util.Map) resources.get(0);
            for ( Object o : resources ) {
                java.util.Map r = (java.util.Map) o;
                if ( Boolean.TRUE.equals( r.get("primary") ) ) { resource = r; }
            }
            java.util.Map resourceRef = (java.util.Map) resource.get("resourceRef");
            kcontext.setVariable("serviceAccessCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if ( !found ) {
    kcontext.setVariable("errorMessage", "Unable to find the SC_ACCESS service component at the given service");
}
System.out.println("Data Outputs: serviceAccessCrossId=" + kcontext.getVariable("serviceAccessCrossId") + ", errorMessage=" + kcontext.getVariable("errorMessage"));]]></bpmn2:script>
    </bpmn2:scriptTask>

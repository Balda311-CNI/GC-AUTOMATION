get data">
      <bpmn2:documentation id="_i3nZzGm9EfGwm_kRKeU4IQ"><![CDATA[Retrieves data from automaton's tmf_store table using TMF_STORE domain and JSONATA transformation.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[TMF_STORE:
get data]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("================================================");
System.out.println("updateCustomerRoom - TMF_STORE: get data");
System.out.println("================================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: version=" + version + ", crossProjectName=" + crossProjectName + ", serviceCrossId=" + serviceCrossId + ", smwRoomId=" + smwRoomId + ", country=" + country);
if ( "DE".equalsIgnoreCase(country) ) {
    kcontext.setVariable("smwSystemId", "PNI_DE");
} else {
    throw new IllegalArgumentException("Unsupported country '" + country + "' - only 'DE' (Germany) is supported for now");
}]]></drools:script>
        </drools:onExit-script>

cross/updateCpeParent">
      <bpmn2:documentation id="_FGfp8GmEEfGwm_kRKeU4IQ"><![CDATA[Re-parent the CPE node to the target room via CROSS API PUT (parents implicitly removed). (UPDATE)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/updateCpeParent]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("================================================");
System.out.println("updateCustomerRoom - REST_API_CALL: cross/updateCpeParent");
System.out.println("================================================");
java.util.List parentCrossIdsList = new java.util.ArrayList();
parentCrossIdsList.add( roomCrossId );
kcontext.setVariable("parentCrossIds", parentCrossIdsList);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>

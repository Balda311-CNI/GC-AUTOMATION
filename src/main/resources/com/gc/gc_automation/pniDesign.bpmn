    <bpmn2:task id="_DF7DBE5F-DCB0-43F2-B5A0-D14E96F15DDF" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findLocalityAndPlaceForAddress">
      <bpmn2:documentation id="_uiXYmzpGEfGeGeWP6G0fcQ"><![CDATA[Finds locality bound to a given addressCrossId. Output resultList may be null or empty - downstream gateway will branch to Create locality and place in that case.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findLocalityAndPlaceForAddress]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("==========================================================================");
System.out.println("=== pniDesign - REST_API_CALL: cross/findLocalityAndBuildingForAddress ===");
System.out.println("==========================================================================");

resultList = null;]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Debug output
System.out.println("Data Outputs: resultList=" + resultList);

if (resultList != null) {
    java.util.List<?> list = (java.util.List<?>) resultList;

    if (list.size() == 1) {
        java.util.Map<String, Object> firstRow = (java.util.Map<String, Object>) list.get(0);

        localityCrossId = ((String) firstRow.get("localityCrossId"));
        System.out.println("localityCrossId=" + localityCrossId);
        kcontext.setVariable("localityCrossId", localityCrossId);

        placeCrossId = ((String) firstRow.get("placeCrossId"));
        System.out.println("placeCrossId=" + placeCrossId);
        kcontext.setVariable("placeCrossId", placeCrossId);
    }
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

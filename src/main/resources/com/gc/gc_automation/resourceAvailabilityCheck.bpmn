      <bpmn2:incoming>_E3E4F928-071F-4C3D-9275-EF8BB519A2DC</bpmn2:incoming>
      <bpmn2:outgoing>_40BC8B83-AB0B-4F07-9D27-C2F6A8776EA1</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("version=" + kcontext.getVariable("version"));
System.out.println("version=" + version);

//String dataOutputs = java.lang.String.format(
//    "version=", version,
//    "odinRequestId=", odinRequestId,
//    "addressMasterId=", addressMasterId,
//    "distance=", distance,
//    "equipmentTypes=", equipmentTypes
//);

String dataOutputs = java.lang.String.format(
    "version=", kcontext.getVariable("version"),
    "odinRequestId=", kcontext.getVariable("odinRequestId"),
    "addressMasterId=", kcontext.getVariable("addressMasterId"),
    "distance=", kcontext.getVariable("distance"),
    "equipmentTypes=", kcontext.getVariable("equipmentTypes")
);

System.out.println("Data Outputs: " + dataOutputs);]]></bpmn2:script>
    </bpmn2:scriptTask>

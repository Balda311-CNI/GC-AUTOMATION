    <bpmn2:task id="_762FDAA2-F5AE-4703-A797-3E4F32217D69" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findEquipments">
      <bpmn2:documentation id="_er9D2jQCEfGP_43KC4m93A"><![CDATA[Calls automatons source with name "cross/executeQuery/findEquipments" using domain REST_API_CALL.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findEquipments]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===========================================================================================");
System.out.println("resourceAvailabilityCheck - REST_API_CALL: REST_API_CALL: cross/executeQuery/findEquipments");
System.out.println("===========================================================================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Debug output
System.out.println("Data Outputs: equipmentList=" + equipmentList);

if (equipmentList != null) {
    java.util.List<?> list = (java.util.List<?>) equipmentList;

    for (Object element : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) element;
        
        // Prepare nested coordinates
        java.util.Map<String, Object> coordinates = new java.util.HashMap<String, Object>();

        Object latObj = row.get("latitude");
        if (latObj != null) {
            coordinates.put("latitude", latObj);
        }

        Object lonObj = row.get("longitude");
        if (lonObj != null) {
            coordinates.put("longitude", lonObj);
        }

        // Remove original fields (safe even if not present)
        row.remove("latitude");
        row.remove("longitude");

        // Add only if at least one coordinate exists
        if (!coordinates.isEmpty()) {
            row.put("coordinates", coordinates);
        }
    }
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

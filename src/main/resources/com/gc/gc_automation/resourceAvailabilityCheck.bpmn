    <bpmn2:scriptTask id="_CE654643-51DE-434D-A897-FE70FCDFE464" name="Initialize" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Initialize]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_57CDA1F2-1213-4E9F-8DBD-C3F9881D1414</bpmn2:incoming>
      <bpmn2:outgoing>_240FD9D0-E876-43E8-8A57-7261325E6082</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================ resourceAvailabilityCheck - Initialize ================");

if (kcontext.getVariable("_apiCallUrl") == null) {
  String glob = (String) kcontext.getKieRuntime().getEnvironment().get("_apiCallUrl");
  if (glob != null) {
    System.out.println();
    kcontext.setVariable("_apiCallUrl", glob);
  } else {
    // Replace with your environment-specific Automaton API URL
    System.out.println("Default _apiCallUrl fallback");
    kcontext.setVariable("_apiCallUrl", "http://192.168.81.37:8085/api/jbpm/apiCall");
  }
}]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:endEvent id="_C0AD0CDB-2EE7-45BD-B205-B4BFBC13AEDF">
      <bpmn2:incoming>_E3E4F928-071F-4C3D-9275-EF8BB519A2DC</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:task id="_8CB7A114-8CEA-4461-8718-36C5581E42D1" drools:taskName="SdcApiCall" name="Get data from TMF_STORE">
      <bpmn2:documentation id="_qkSDcSxiEfGA0YQk2TA4dg"><![CDATA[sdc-jbpm/index.html]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Get data from TMF_STORE]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("================ resourceAvailabilityCheck - Get data from TMF_STORE ================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Get inspired at: AutomatonTM.CREATE_ORDER_PI_API
String dataOutputs = java.lang.String.format(
    "version=%s, odinRequestId=%s, addressMasterId=%s, distance=%d, equipmentTypes=%s",
    version,
    odinRequestId,
    addressMasterId,
    distance,
    equipmentTypes == null ? "" : equipmentTypes.toString()
);
System.out.println("Data Outputs: " + dataOutputs);]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

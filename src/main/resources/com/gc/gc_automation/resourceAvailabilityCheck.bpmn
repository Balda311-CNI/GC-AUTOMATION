    <bpmn2:task id="_8CB7A114-8CEA-4461-8718-36C5581E42D1" drools:taskName="SdcApiCall" name="Get data from TMF_STORE">
      <bpmn2:documentation id="_U-n0BC2eEfGfoZQg-BFILQ"><![CDATA[sdc-jbpm/index.html]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Get data from TMF_STORE]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("================ resourceAvailabilityCheck - Get data from TMF_STORE ================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Get inspired at: AutomatonTM.CREATE_ORDER_PI_API
String dataOutputs = java.lang.String.format(
    "version=%s, odinRequestId=%s, addressMasterId=%s, distance=%d, equipmentTypes=%s",
    version,
    odinRequestId,
    addressMasterId,
    distance,
    equipmentTypes == null ? "" : equipmentTypes.toString()
);
System.out.println("Data Outputs: " + dataOutputs);]]></drools:script>
        </drools:onExit-script>

    <bpmn2:task id="_8CB7A114-8CEA-4461-8718-36C5581E42D1" drools:taskName="SdcApiCall" name="TMF_STORE:
get data">
      <bpmn2:documentation id="_ikUjkzc0EfGEt-bONYJHMQ"><![CDATA[Retrieves data from automaton's tmf_store table using TMF_STORE domain and JSONATA transformation.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[TMF_STORE:
get data]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===================================================");
System.out.println("resourceAvailabilityCheck - Get data from TMF_STORE");
System.out.println("===================================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Get inspired at: AutomatonTM.CREATE_ORDER_PI_API
String dataOutputs = java.lang.String.format(
    "version=%s, addressMasterId=%s, distance=%d, equipmentTypes=%s",
    version,
    addressMasterId,
    distance,
    equipmentTypes == null ? "" : equipmentTypes.toString()
);
System.out.println("Data Outputs: " + dataOutputs);]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

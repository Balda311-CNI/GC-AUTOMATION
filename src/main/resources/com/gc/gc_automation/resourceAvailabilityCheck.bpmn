    <bpmn2:scriptTask id="_CE654643-51DE-434D-A897-FE70FCDFE464" name="Initialize" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Initialize]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_57CDA1F2-1213-4E9F-8DBD-C3F9881D1414</bpmn2:incoming>
      <bpmn2:outgoing>_240FD9D0-E876-43E8-8A57-7261325E6082</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================ resourceAvailabilityCheck - Initialize ================");

if (kcontext.getVariable("_apiCallUrl") == null) {
  String glob = (String) kcontext.getKieRuntime().getEnvironment().get("_apiCallUrl");
  if (glob != null) {
    System.out.println();
    kcontext.setVariable("_apiCallUrl", glob);
  } else {
    // Replace with your environment-specific Automaton API URL
    System.out.println("Default _apiCallUrl fallback");
    kcontext.setVariable("_apiCallUrl", "http://192.168.81.37:8085/api/jbpm/apiCall");
  }
}]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:endEvent id="_C0AD0CDB-2EE7-45BD-B205-B4BFBC13AEDF">

    <bpmn2:task id="_CA09AB50-A6C1-43DA-97F7-F3D92BC8EC85" drools:taskName="SdcApiCall" name="REST_API_CALL: cross/executeQuery/findAddress">
      <bpmn2:documentation id="_tbmdQC2aEfGfoZQg-BFILQ"><![CDATA[sdc-jbpm/index.html]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL: cross/executeQuery/findAddress]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("================ resourceAvailabilityCheck - REST_API_CALL: cross/executeQuery/findAddress ================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Get inspired at: AutomatonTM.CREATE_ORDER_PI_API
String dataOutputs = java.lang.String.format(
    "addressList=%s",
    addressList != null ? addressList.toString() : null
);
System.out.println("Data Outputs: " + dataOutputs);

if (addressList != null && !addressList.isEmpty()) {
    java.util.Map<String, Object> firstRow = addressList.get(0);

    addressLatitude = ((Number) row.get("latitude")).floatValue();
    System.out.println("addressLatitude=" + addressLatitude);
    
    addressLongitude = ((Number) row.get("longitude")).floatValue();
    System.out.println("addressLongitude=" + addressLongitude);
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

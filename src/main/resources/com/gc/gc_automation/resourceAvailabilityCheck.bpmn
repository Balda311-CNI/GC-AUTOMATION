    <bpmn2:task id="_8D857E7A-9534-477A-8E8D-AF508CF19986" drools:taskName="SdcApiCall" name="REST_API_CALL:
automaton/tmf/put">
      <bpmn2:documentation id="_Po86hjQJEfGEt-bONYJHMQ"><![CDATA[Calls automatons source with name "automaton/tmf/put" using domain REST_API_CALL.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
automaton/tmf/put]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===========================================================================");
System.out.println("resourceAvailabilityCheck - REST_API_CALL: automaton/tmf/put");
System.out.println("===========================================================================");

java.util.Map<String, Object> dataAddressCoordinates = new java.util.HashMap<String, Object>();
dataAddressCoordinates.put("latitude", kcontext.getVariable("addressLatitude"));
dataAddressCoordinates.put("longitude", kcontext.getVariable("addressLongitude"));

java.util.Map<String, Object> dataAddress = new java.util.HashMap<String, Object>();
dataAddress.put("addressMasterId", kcontext.getVariable("addressMasterId"));
dataAddress.put("coordinates", dataAddressCoordinates);

java.util.Map<String, Object> map = new java.util.HashMap<String, Object>();
map.put("id", kcontext.getVariable("_order"));
map.put("version", kcontext.getVariable("version"));
map.put("odinRequestId", kcontext.getVariable("odinRequestId"));
map.put("status", "COMPLETED");
map.put("address", dataAddress);
map.put("results", kcontext.getVariable("equipmentList"));
kcontext.setVariable("response", map);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>

      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_WSM1QTQAEfGP_43KC4m93A" language="http://www.java.com/java"><![CDATA[boolean result = addressList != null && ((java.util.List<?>) addressList).size() > 1;
System.out.println("VALIDATION: Address not unique: " + result );
if (result) {
    kcontext.setVariable("error", "ERROR: Address not unique");
}
return result;]]></bpmn2:conditionExpression>

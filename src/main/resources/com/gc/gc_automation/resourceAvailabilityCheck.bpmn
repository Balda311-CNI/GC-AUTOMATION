    <bpmn2:scriptTask id="_D99C7DAD-1C65-4F7E-A65C-C2CCBB40E6B3" name="Create result:
COMPLETED" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Create result:
COMPLETED]]></drools:metaValue>

      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - Create result: COMPLETED");
System.out.println("================================================");

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("id", kcontext.getVariable("_order"));
map.put("status", "COMPLETED");
map.put("projectCrossId", kcontext.getVariable("projectCrossId"));
map.put("cpeCrossId", kcontext.getVariable("cpeCrossId"));
map.put("customerSideCageCrossId", kcontext.getVariable("customerSideCageCrossId"));
map.put("customerSidePatchCordCrossId", kcontext.getVariable("customerSidePatchCordCrossId"));
map.put("networkSideCageCrossId", kcontext.getVariable("networkSideCageCrossId"));
map.put("networkSidePlaceCrossId", kcontext.getVariable("networkSidePlaceCrossId"));
map.put("networkSidePatchCordCrossId", kcontext.getVariable("networkSidePatchCordCrossId"));
map.put("ethLinkCrossId", kcontext.getVariable("ethLinkCrossId"));
map.put("opticalPathCrossId", kcontext.getVariable("opticalPathCrossId"));
kcontext.setVariable("response", map);]]></bpmn2:script>

      <bpmn2:documentation id="_yjSqc2PcEfGfPMT-FbzZ9A"><![CDATA[Find a PLACE parent (not necessarily direct) for edgeEquipmentCrossId via CROSS PROJECT API. (FIND)]]></bpmn2:documentation>
      <bpmn2:extensionElements>

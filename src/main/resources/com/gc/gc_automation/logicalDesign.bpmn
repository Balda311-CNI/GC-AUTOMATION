    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("PHYSICAL_CONNECTIVITY".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component PHYSICAL_CONNECTIVITY has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;

            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("opticalPathCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component PHYSICAL_CONNECTIVITY at the given service");
}
System.out.println("opticalPathCrossId=" + kcontext.getVariable("opticalPathCrossId"));]]></bpmn2:script>

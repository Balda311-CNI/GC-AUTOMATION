    <bpmn2:task id="_0C0EFC6D-9912-48CD-8280-FD685B0D4070" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findNetworkSidePlace">
      <bpmn2:documentation id="_-cKwMWC8EfGFt4OFFnO5tA"><![CDATA[Find a PLACE parent (not necessarily direct) for edgeEquipmentCrossId via CROSS PROJECT API. (FIND)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findNetworkSidePlace]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("====================================================================");
System.out.println("logicalDesign - REST_API_CALL: cross/executeQuery/findNetworkSidePlace");
System.out.println("====================================================================");

resultList = null;]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: resultList=" + resultList);
if (resultList == null || ((java.util.List<?>) resultList).isEmpty()) {
    kcontext.setVariable("errorMessage", "Network side PLACE not found");
} else if (((java.util.List<?>) resultList).size() > 1) {
    kcontext.setVariable("errorMessage", "Network side PLACE not unique");
} else {
    Object first = ((java.util.List<?>) resultList).get(0);
    String value = (first instanceof java.util.Map)
        ? (String) ((java.util.Map<String, Object>) first).get("crossId")
        : (String) first;
    kcontext.setVariable("networkSidePlaceCrossId", value);
    System.out.println("networkSidePlaceCrossId=" + value);
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

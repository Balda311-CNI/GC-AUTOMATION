    <bpmn2:task id="_3EAA8729-B3A0-4CEE-8B2F-2AEB9B552696" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findNodeNames">
      <bpmn2:documentation id="_XtWXwGPbEfGfPMT-FbzZ9A"><![CDATA[sdc-jbpm/index.html]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findNodeNames]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("=========================================");
System.out.println("logicalDesign - build criteria for nodeCriteria");
System.out.println("=========================================");

java.util.List ids = new java.util.ArrayList();
if (edgeEquipmentCrossId != null) ids.add(edgeEquipmentCrossId);
if (networkSideCageCrossId != null) ids.add(networkSideCageCrossId);
if (customerSideCageCrossId != null) ids.add(customerSideCageCrossId);
if (cpeCrossId != null) ids.add(cpeCrossId);
if (customerSidePlaceCrossId != null) ids.add(customerSidePlaceCrossId);
StringBuilder sb = new StringBuilder();
for (int i = 0; i < ids.size(); i++) { if (i > 0) sb.append(";"); sb.append("externalId=").append(ids.get(i)); }
kcontext.setVariable("nodeCriteria", sb.toString());]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>

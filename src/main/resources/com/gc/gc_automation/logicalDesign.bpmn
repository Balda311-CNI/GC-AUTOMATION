      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - Create result: COMPLETED");
System.out.println("================================================");

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("version", "1.0");
map.put("status", "COMPLETED");
map.put("serviceCrossId", kcontext.getVariable("serviceCrossId"));

java.util.Map<String, Object> networkSideMap = new java.util.HashMap<>();
networkSideMap.put("cageCrossId", kcontext.getVariable("networkSideCageCrossId"));
networkSideMap.put("cageName", kcontext.getVariable("networkSideCageName"));
networkSideMap.put("edgeEquipmentCrossId", kcontext.getVariable("edgeEquipmentCrossId"));
networkSideMap.put("edgeEquipmentName", kcontext.getVariable("edgeEquipmentName"));
networkSideMap.put("patchCordCrossId", kcontext.getVariable("networkSidePatchCordCrossId"));
networkSideMap.put("patchCordName", kcontext.getVariable("networkSidePatchCordName"));
//networkSideMap.put("portCrossId", kcontext.getVariable("networkSidePortCrossId"));
//networkSideMap.put("portName", kcontext.getVariable("networkSidePortName"));
map.put("edgeEquipment", networkSideMap);

java.util.Map<String, Object> edgeEquipmentMap = new java.util.HashMap<>();
edgeEquipmentMap.put("cageCrossId", kcontext.getVariable("customerSideCageCrossId"));
edgeEquipmentMap.put("cageName", kcontext.getVariable("customerSideCageName"));
edgeEquipmentMap.put("cpeCrossId", kcontext.getVariable("cpeCrossId"));
edgeEquipmentMap.put("cpeName", kcontext.getVariable("cpeName"));
edgeEquipmentMap.put("patchCordCrossId", kcontext.getVariable("customerSidePatchCordCrossId"));
edgeEquipmentMap.put("patchCordName", kcontext.getVariable("customerSidePatchCordName"));
//edgeEquipmentMap.put("portCrossId", kcontext.getVariable("customerSidePortCrossId"));
//edgeEquipmentMap.put("portName", kcontext.getVariable("customerSidePortName"));
edgeEquipmentMap.put("placeCrossId", kcontext.getVariable("customerSidePlaceCrossId"));
edgeEquipmentMap.put("placeName", kcontext.getVariable("customerSidePlaceName"));
edgeEquipmentMap.put("placeSmwId", kcontext.getVariable("customerSidePlaceSmwId"));
//edgeEquipmentMap.put("localityCrossId", kcontext.getVariable("customerSideLocalityCrossId"));
//edgeEquipmentMap.put("localityName", kcontext.getVariable("customerSideLocalityName"));
//edgeEquipmentMap.put("localitySmwId", kcontext.getVariable("customerSideLocalitySmwId"));
map.put("customerEquipment", edgeEquipmentMap);

map.put("ethLinkCrossId", kcontext.getVariable("ethLinkCrossId"));
map.put("ethLinkName", kcontext.getVariable("ethLinkName"));
//map.put("networkSidePlaceCrossId", kcontext.getVariable("networkSidePlaceCrossId"));
//map.put("opticalCircuitCrossId", kcontext.getVariable("opticalPathCrossId"));

kcontext.setVariable("response", map);]]></bpmn2:script>
    </bpmn2:scriptTask>

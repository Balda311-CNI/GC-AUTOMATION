    <bpmn2:scriptTask id="_2A00FC8E-90BE-48A0-B4E2-E5756F80558B" name="find
opticalPath" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
opticalPath]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_5FA89BE2-02B2-4903-BAFD-2C912D2E1D61</bpmn2:incoming>
      <bpmn2:outgoing>_7F252FB6-BC09-4AB5-93D6-91A7470A4EFF</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - find opticalPath");
System.out.println("================================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("servicePhysicalAccessComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("PHYSICAL_CONNECTIVITY".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component PHYSICAL_CONNECTIVITY has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("opticalPathCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component PHYSICAL_CONNECTIVITY at the given service");
}
System.out.println("opticalPathCrossId=" + kcontext.getVariable("opticalPathCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>

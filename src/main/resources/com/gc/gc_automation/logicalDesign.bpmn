    <bpmn2:task id="_BB5FD692-C3C5-4F05-BF8B-A96430A90365" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findLinkNames">
      <bpmn2:documentation id="_yjSqhmPcEfGfPMT-FbzZ9A"><![CDATA[sdc-jbpm/index.html]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findLinkNames]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("=========================================");
System.out.println("logicalDesign - build criteria for linkCriteria");
System.out.println("=========================================");

java.util.List ids = new java.util.ArrayList();
if (customerSidePatchCordCrossId != null) ids.add(customerSidePatchCordCrossId);
if (networkSidePatchCordCrossId != null) ids.add(networkSidePatchCordCrossId);
if (ethLinkCrossId != null) ids.add(ethLinkCrossId);
StringBuilder sb = new StringBuilder();
for (int i = 0; i < ids.size(); i++) { if (i > 0) sb.append(";"); sb.append("externalId=").append(ids.get(i)); }
kcontext.setVariable("linkCriteria", sb.toString());]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[java.util.List items = (java.util.List) resultList;
if (items != null) {
    for (Object itemObj : items) {
        java.util.Map item = (java.util.Map) itemObj;
        String nm = (String) item.get("name");
        String cid = null;
        Object extsObj = item.get("externalIds");
        if (extsObj != null) {
            for (Object eObj : (java.util.List) extsObj) {
                java.util.Map e = (java.util.Map) eObj;
                if ("CROSS".equals(e.get("systemId"))) { cid = (String) e.get("externalId"); break; }
            }
        }
        if (cid == null) continue;
        if (cid.equals(customerSidePatchCordCrossId))     kcontext.setVariable("customerSidePatchCordName", nm);
        else if (cid.equals(networkSidePatchCordCrossId)) kcontext.setVariable("networkSidePatchCordName", nm);
        else if (cid.equals(ethLinkCrossId))              kcontext.setVariable("ethLinkName", nm);
    }
}
]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

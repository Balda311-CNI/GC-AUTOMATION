    <bpmn2:task id="_95FC3D56-3626-495B-97C9-D7522B6A02D9" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/updateEthLinkProviders">
      <bpmn2:documentation id="_tVJ5SmMVEfGFt4OFFnO5tA"><![CDATA[Set networkSidePatchCord, opticalPath and customerSidePatchCord as providers of ethLinkCrossId. (CREATE_OR_UPDATE)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/updateEthLinkProviders]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("=========================================================");
System.out.println("logicalDesign - REST_API_CALL: cross/updateEthLinkProviders");
System.out.println("=========================================================");

java.util.List<Object> providers = new java.util.ArrayList<>();

java.util.Map<String, Object> opticalPath = new java.util.HashMap<>();
opticalPath.put("providerCrossId", kcontext.getVariable("opticalPathCrossId"));
opticalPath.put("consumptionType", "MAIN");
opticalPath.put("reversed", false);
opticalPath.put("orderNumber", 1);
opticalPath.put("fibrilNumber", 1);
providers.add(opticalPath);

kcontext.setVariable("ethLinkProviders", providers);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>

        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: resultList=" + resultList);
if (resultList == null || ((java.util.List<?>) resultList).isEmpty()) {
    kcontext.setVariable("errorMessage", "Customer side CAGE not found");
} else if (((java.util.List<?>) resultList).size() > 1) {
    kcontext.setVariable("errorMessage", "Customer side CAGE not unique");
} else {
    Object first = ((java.util.List<?>) resultList).get(0);
    String value = (first instanceof java.util.Map)
        ? (String) ((java.util.Map<String, Object>) first).get("crossId")
        : (String) first;
    kcontext.setVariable("customerSideCageCrossId", value);
    System.out.println("customerSideCageCrossId=" + value);
}]]></drools:script>

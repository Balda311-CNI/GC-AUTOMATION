    <bpmn2:scriptTask id="_B170C4CE-FF4F-4C96-9E02-EBC4DE85A640" name="find
serviceAccessCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
serviceAccessCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_DE23C89D-0718-4411-8D12-1197CD7D8962</bpmn2:incoming>
      <bpmn2:outgoing>_2F2F01C7-3741-401E-B476-FF39AA84B301</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - find serviceAccessCrossId");
System.out.println("================================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("serviceComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("SC_ACCESS".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component SC_ACCESS has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("serviceAccessCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component SC_ACCESS at the given service");
}
System.out.println("serviceAccessCrossId=" + kcontext.getVariable("serviceAccessCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>

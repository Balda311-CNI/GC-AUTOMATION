      <bpmn2:outgoing>_77EEACF7-E1A6-4E42-93AC-37156732FDB9</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("==================================");
System.out.println("=== logicalDesign - Initialize ===");
System.out.println("==================================");

//kcontext.setVariable("reservedStatusDiscriminator", "RESERVED");

kcontext.setVariable("cageStatuses", java.util.Arrays.asList("ACTIVE", "DESIGNED"));]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:task id="_6EB922B0-824E-498B-A0A2-DBCED705DE5F" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findCustomerSideCage">
      <bpmn2:documentation id="_pYrIz2N3EfGFt4OFFnO5tA"><![CDATA[Find a CAGE under the deployed cpeCrossId via CROSS PROJECT API. (FIND - depends on created cpeCrossId)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findCustomerSideCage]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("====================================================================");
System.out.println("logicalDesign - REST_API_CALL: cross/executeQuery/findCustomerSideCage");
System.out.println("====================================================================");

resultList = null;]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: resultList=" + resultList);
if (resultList == null || ((java.util.List<?>) resultList).isEmpty()) {
    kcontext.setVariable("errorMessage", "Customer side CAGE not found");
} else if (((java.util.List<?>) resultList).size() > 1) {
    kcontext.setVariable("errorMessage", "Customer side CAGE not unique");
} else {
    Object first = ((java.util.List<?>) resultList).get(0);
    String value = (first instanceof java.util.Map)
        ? (String) ((java.util.Map<String, Object>) first).get("crossId")
        : (String) first;
    kcontext.setVariable("customerSideCageCrossId", value);
    System.out.println("customerSideCageCrossId=" + value);
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

    <bpmn2:scriptTask id="_5199A53B-A868-4B4E-A5DC-70030178877C" name="distribute node and link names" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[distribute node and link names]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_FA595EC6-4BFE-4576-8E69-CB4051CC0049</bpmn2:incoming>
      <bpmn2:outgoing>_42C75F97-536B-41B3-816E-0D8B965E367B</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("========================================");
System.out.println("logicalDesign - distribute node and link names");
System.out.println("========================================");

java.util.List all = new java.util.ArrayList();
if (nodeNameList != null) all.addAll((java.util.List) nodeNameList);
if (linkNameList != null) all.addAll((java.util.List) linkNameList);
java.util.Map nameByCrossId = new java.util.HashMap();
java.util.Map smwByCrossId = new java.util.HashMap();
for (Object itemObj : all) {
    java.util.Map item = (java.util.Map) itemObj;
    String nm = (String) item.get("name");
    String cid = null; String smw = null;
    Object extsObj = item.get("externalIds");
    if (extsObj != null) {
        for (Object eObj : (java.util.List) extsObj) {
            java.util.Map e = (java.util.Map) eObj;
            if ("CROSS".equals(e.get("systemId"))) cid = (String) e.get("externalId");
            if ("SMW".equals(e.get("systemId"))) smw = (String) e.get("externalId");
        }
    }
    if (cid != null) { nameByCrossId.put(cid, nm); if (smw != null) smwByCrossId.put(cid, smw); }
}
kcontext.setVariable("edgeEquipmentName", nameByCrossId.get(edgeEquipmentCrossId));
kcontext.setVariable("networkSideCageName", nameByCrossId.get(networkSideCageCrossId));
kcontext.setVariable("customerSideCageName", nameByCrossId.get(customerSideCageCrossId));
kcontext.setVariable("cpeName", nameByCrossId.get(cpeCrossId));
kcontext.setVariable("customerSidePlaceName", nameByCrossId.get(customerSidePlaceCrossId));
kcontext.setVariable("customerSidePlaceSmwId", smwByCrossId.get(customerSidePlaceCrossId));
kcontext.setVariable("customerSidePatchCordName", nameByCrossId.get(customerSidePatchCordCrossId));
kcontext.setVariable("networkSidePatchCordName", nameByCrossId.get(networkSidePatchCordCrossId));
kcontext.setVariable("ethLinkName", nameByCrossId.get(ethLinkCrossId));]]></bpmn2:script>
    </bpmn2:scriptTask>

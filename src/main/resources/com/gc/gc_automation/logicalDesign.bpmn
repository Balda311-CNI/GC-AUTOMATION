    <bpmn2:scriptTask id="_3A967505-D7CE-4E59-8691-ADFE250D498F" name="find
servicePhysicalAccessCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
servicePhysicalAccessCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_B6CB2B83-10B7-4446-A832-AA8FD1D4253F</bpmn2:incoming>
      <bpmn2:outgoing>_7709AD85-1029-4A42-9AC0-66970F2AF8A9</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - find servicePhysicalAccessCrossId");
System.out.println("================================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("serviceAccessComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("SC_PHYSICAL_ACCESS".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component SC_PHYSICAL_ACCESS has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("servicePhysicalAccessCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component SC_PHYSICAL_ACCESS at the given service");
}
System.out.println("servicePhysicalAccessCrossId=" + kcontext.getVariable("servicePhysicalAccessCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>

    <bpmn2:scriptTask id="_E3FF4E65-7DF5-4539-AA76-D274FD7B1429" name="find
customerSidePlaceCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
customerSidePlaceCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_784F4664-7983-4744-B43D-E446E6F4F079</bpmn2:incoming>
      <bpmn2:outgoing>_A1655C03-F4A2-4187-8720-316BBFF78802</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - find customerSidePlaceCrossId");
System.out.println("================================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("servicePhysicalAccessComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("PLACEMENT".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component PLACEMENT has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("customerSidePlaceCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component PLACEMENT at the given service");
}
System.out.println("customerSidePlaceCrossId=" + kcontext.getVariable("customerSidePlaceCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:task id="_0C0EFC6D-9912-48CD-8280-FD685B0D4070" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findNetworkSidePlace">
      <bpmn2:documentation id="_0mu00V_7EfGRstmrwDP8aA"><![CDATA[Find a PLACE parent (not necessarily direct) for edgeEquipmentCrossId via CROSS PROJECT API. (FIND)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findNetworkSidePlace]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("====================================================================");
System.out.println("logicalDesign - REST_API_CALL: cross/executeQuery/findNetworkSidePlace");
System.out.println("====================================================================");

resultList = null;]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: resultList=" + resultList);
if (resultList == null || ((java.util.List<?>) resultList).isEmpty()) {
    kcontext.setVariable("errorMessage", "Network side PLACE not found");
} else if (((java.util.List<?>) resultList).size() > 1) {
    kcontext.setVariable("errorMessage", "Network side PLACE not unique");
} else {
    Object first = ((java.util.List<?>) resultList).get(0);
    String value = (first instanceof java.util.Map)
        ? (String) ((java.util.Map<String, Object>) first).get("crossId")
        : (String) first;
    kcontext.setVariable("networkSidePlaceCrossId", value);
    System.out.println("networkSidePlaceCrossId=" + value);
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

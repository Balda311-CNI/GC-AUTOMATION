    <bpmn2:scriptTask id="_38B40D59-2223-4EF5-BC7B-A6882045E550" name="find
customerSidePlaceCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
customerSidePlaceCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_301BECA2-A12F-44DF-804E-A4E696C656CF</bpmn2:incoming>
      <bpmn2:outgoing>_108941B9-F51D-4CB0-A532-166428C6B41C</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("================================================");
System.out.println("logicalDesign - find customerSidePlaceCrossId");
System.out.println("================================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("servicePhysicalAccessComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("PLACEMENT".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component PLACEMENT has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("customerSidePlaceCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component PLACEMENT at the given service");
}
System.out.println("customerSidePlaceCrossId=" + kcontext.getVariable("customerSidePlaceCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>

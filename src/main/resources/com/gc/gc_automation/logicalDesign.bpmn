    <bpmn2:scriptTask id="_D6AA444B-A7E2-41F3-9F68-B09CEF591DD4" name="find
networkSideCageCrossId" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[find
networkSideCageCrossId]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_52F6EC8B-F6B7-41C3-871D-437CFFF1656B</bpmn2:incoming>
      <bpmn2:outgoing>_92DE4E87-C6BD-4C02-AD85-BA3BEE5F3C32</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("===========================================");
System.out.println("logicalDesign - find networkSideCageCrossId");
System.out.println("===========================================");

java.util.List<?> components = (java.util.List<?>) kcontext.getVariable("serviceAccessComponents");
boolean found = false;
if (components != null) {
    for (Object item : components) {
        java.util.Map<String, Object> sc = (java.util.Map<String, Object>) item;
        if ("ACCESS_EQUIPMENT_PORT".equals(sc.get("componentTypeName"))) {
            java.util.List<?> resources = (java.util.List<?>) sc.get("resources");
            if (resources == null || resources.isEmpty()) {
                kcontext.setVariable("errorMessage", "Service component ACCESS_EQUIPMENT_PORT has no resources");
                return;
            }
            java.util.Map<String, Object> resource = (java.util.Map<String, Object>) resources.get(0);
            if (resources.size() > 1) {
                for (Object ro : resources) {
                    java.util.Map<String, Object> r = (java.util.Map<String, Object>) ro;
                    Object primary = r.get("primary");
                    if (primary != null && ((Boolean) primary).booleanValue()) {
                        resource = r;
                    }
                }
            }
            java.util.Map<String, Object> resourceRef = (java.util.Map<String, Object>) resource.get("resourceRef");
            kcontext.setVariable("networkSideCageCrossId", (String) resourceRef.get("id"));
            found = true;
        }
    }
}
if (!found) {
    kcontext.setVariable("errorMessage", "Unable to find service component ACCESS_EQUIPMENT_PORT at the given service");
}
System.out.println("networkSideCageCrossId=" + kcontext.getVariable("networkSideCageCrossId"));]]></bpmn2:script>
    </bpmn2:scriptTask>

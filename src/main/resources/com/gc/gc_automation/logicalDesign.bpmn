    <bpmn2:task id="_3756C96C-98B7-4F97-B9D7-C2A5AA4F4436" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findNetworkSideCage">
      <bpmn2:documentation id="_KEzxAmCkEfGoGZGuksU-9A"><![CDATA[Find a CAGE under the input edgeEquipmentCrossId via CROSS PROJECT API. (FIND)]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findNetworkSideCage]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===================================================================");
System.out.println("logicalDesign - REST_API_CALL: cross/executeQuery/findNetworkSideCage");
System.out.println("===================================================================");

resultList = null;]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: resultList=" + resultList);
if (resultList == null || ((java.util.List<?>) resultList).isEmpty()) {
    kcontext.setVariable("errorMessage", "Network side CAGE not found");
} else if (((java.util.List<?>) resultList).size() > 1) {
    kcontext.setVariable("errorMessage", "Network side CAGE not unique");
} else {
    Object first = ((java.util.List<?>) resultList).get(0);
    String value = (first instanceof java.util.Map)
        ? (String) ((java.util.Map<String, Object>) first).get("crossId")
        : (String) first;
    kcontext.setVariable("networkSideCageCrossId", value);
    System.out.println("networkSideCageCrossId=" + value);
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>

    <bpmn2:sequenceFlow id="_50F5E74C-DDA4-4A2F-B96C-199C0A076442" name="SC_PHYSICAL_ACCESS" sourceRef="_09692EE6-0B58-4A39-B5EF-1DE3B9324790" targetRef="_0E35A2C2-1E0D-4169-8A66-BCF012682E82">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[SC_PHYSICAL_ACCESS]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_CCfoIUGdEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = false;
if (serviceComponents != null) {
    java.util.List<?> list = (java.util.List<?>) serviceComponents;
    for (Object item : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) item;
        String componentTypeName = (String) row.get("componentTypeName");
        if ("SC_PHYSICAL_ACCESS".equals(componentTypeName)) {
            kcontext.setVariable("serviceComponentAccessEquipmentPortCrossId", (String) row.get("crossId"));
            result = true;
        }
    }
}
System.out.println("VALIDATION: Service with SC_PHYSICAL_ACCESS service component: " + result);
return result;]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>

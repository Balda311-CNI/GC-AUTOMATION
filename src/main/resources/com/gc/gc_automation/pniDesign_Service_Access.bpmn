    <bpmn2:task id="_F352A435-5730-4BDA-9D4E-F08A09613C30" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/addCageToAServiceComponent">
      <bpmn2:documentation id="_RRXw70GeEfGrK4FBZUBLpg"><![CDATA[Add provisioning Cage to a Service Component of the created Service.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/addCageToAServiceComponent]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("==================================================================================");
System.out.println("=== pniDesign_Service_Access - REST_API_CALL: cross/addCageToAServiceComponent ===");
System.out.println("==================================================================================");

java.util.List<Object> list = new java.util.ArrayList<>();

java.util.Map<String, Object> resource = new java.util.HashMap<>();
resource.put("crossId", kcontext.getVariable("cageCrossId"));
resource.put("primary", true);
list.add(resource);

kcontext.setVariable("serviceComponentAccessEquipmentPortResources", list);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>

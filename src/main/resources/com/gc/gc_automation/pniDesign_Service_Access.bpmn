    <bpmn2:sequenceFlow id="_54B0AFF5-98E2-4974-94A2-B24A47EFE18E" sourceRef="_BEA68296-0D68-46E0-A21B-550C2DBA63EE" targetRef="_F352A435-5730-4BDA-9D4E-F08A09613C30">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_kH-pUUDlEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = false;
if (serviceComponents != null) {
    java.util.List<?> list = (java.util.List<?>) serviceComponents;
    for ((java.util.Map<String, Object>) row : list) {
        String componentTypeName = ((String) row.get("componentTypeName"));
        if ("ACCESS_EQUIPMENT_PORT".equals(componentTypeName)) {
            kcontext.setVariable("serviceComponentAccessEquipmentPortCrossId", (String) row.get("crossId"));
            result = true;
        }
    }
}
System.out.println("VALIDATION: Service with ACCESS_EQUIPMENT_PORT service component: " + result);
return result;]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>

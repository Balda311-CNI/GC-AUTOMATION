    <bpmn2:sequenceFlow id="_B013D6BA-C99E-4E19-A9D0-EB43FEDFB41D" name="PHYSICAL_CONNECTIVITY" sourceRef="_9A8B4FB1-0B86-4AF4-B0E7-74815845B805" targetRef="_EFEED2F2-D72F-4F9F-890D-70F6C5CF29BE">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[PHYSICAL_CONNECTIVITY]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_87bD0UGgEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = false;
if (serviceComponents != null) {
    java.util.List<?> list = (java.util.List<?>) serviceComponents;
    for (Object item : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) item;
        String componentTypeName = (String) row.get("componentTypeName");
        if ("PHYSICAL_CONNECTIVITY".equals(componentTypeName)) {
            kcontext.setVariable("serviceComponentPhysicalConnectivityCrossId", (String) row.get("crossId"));
            result = true;
        }
    }
}
System.out.println("VALIDATION: Service with PHYSICAL_CONNECTIVITY service component: " + result);
return result;]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>

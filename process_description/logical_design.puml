    /'Script: "find opticalPath"
    Description: Find service component PHYSICAL_CONNECTIVITY in servicePhysicalAccessComponents and read its resource id.
    Type: FIND

    boolean found = false;
    for ( Map<String, Object> serviceComponent : servicePhysicalAccessComponents ) {
        if ( "PHYSICAL_CONNECTIVITY".equals( serviceComponent.get("componentTypeName") ) ) {
            List<Map<String, Object>> resources = (List) serviceComponent.get("resources");
            if ( resources == null || resources.isEmpty() ) {
                errorMessage = "Service component PHYSICAL_CONNECTIVITY has no resources";
                return;
            }
            // pick the resource: if there are several, take the one with primary == true, otherwise the first
            Map<String, Object> resource = resources.get(0);
            for ( Map<String, Object> r : resources ) {
                if ( Boolean.TRUE.equals( r.get("primary") ) ) { resource = r; }
            }
            Map<String, Object> resourceRef = (Map) resource.get("resourceRef");
            opticalPathCrossId = (String) resourceRef.get("id");
            found = true;
        }
    }
    if ( !found ) {
        errorMessage = "Unable to find service component PHYSICAL_CONNECTIVITY at the given service";
    }

    Gateway:

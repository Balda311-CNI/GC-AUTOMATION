    /'Script: "find servicePhysicalAccessCrossId"
    Description: Find service component SC_PHYSICAL_ACCESS in serviceComponents and read its resource id.
    Type: FIND

    boolean found = false;
    for ( Map<String, Object> serviceComponent : serviceComponents ) {
        if ( "SC_PHYSICAL_ACCESS".equals( serviceComponent.get("componentTypeName") ) ) {
            List<Map<String, Object>> resources = (List) serviceComponent.get("resources");
            if ( resources == null || resources.isEmpty() ) {
                errorMessage = "Service component SC_PHYSICAL_ACCESS has no resources";
                return;
            }
            // pick the resource: if there are several, take the one with primary == true, otherwise the first
            Map<String, Object> resource = resources.get(0);
            for ( Map<String, Object> r : resources ) {
                if ( Boolean.TRUE.equals( r.get("primary") ) ) { resource = r; }
            }
            Map<String, Object> resourceRef = (Map) resource.get("resourceRef");
            servicePhysicalAccessCrossId = (String) resourceRef.get("id");
            found = true;
        }
    }
    if ( !found ) {
        errorMessage = "Unable to find service component SC_PHYSICAL_ACCESS at the given service";
    }

    Gateway:
    If errorMessage != null => invoke Intermediate Link "Failed".
    Default => SdcApiCall: "REST_API_CALL \n cross/findService/SC_PHYSICAL_ACCESS"
    '/

